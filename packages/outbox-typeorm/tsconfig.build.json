{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "test/**/*",
    "**/__tests__/**",
    "dist",
    "node_modules",
    "coverage"
  ],
  "references": [
    { "path": "../core/tsconfig.build.json" },
    { "path": "../typeorm/tsconfig.build.json" },
    { "path": "../outbox/tsconfig.build.json" }
  ]
}
