{
  "name": "@nestjs-transactional/outbox-typeorm",
  "version": "1.0.0-alpha.0",
  "description": "TypeORM persistence backend for @nestjs-transactional/outbox — event_publication table, FOR UPDATE SKIP LOCKED worker safety",
  "license": "MIT",
  "author": "Igor Golovanov",
  "repository": {
    "type": "git",
    "url": "https://github.com/igorgolovanov/nestjs-transactional.git",
    "directory": "packages/outbox-typeorm"
  },
  "bugs": {
    "url": "https://github.com/igorgolovanov/nestjs-transactional/issues"
  },
  "homepage": "https://github.com/igorgolovanov/nestjs-transactional/tree/main/packages/outbox-typeorm#readme",
  "keywords": [
    "nestjs",
    "typeorm",
    "outbox",
    "event-publication-registry",
    "spring-modulith",
    "transactional-outbox"
  ],
  "engines": {
    "node": ">=22.11.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "!dist/**/*.spec.*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist *.tsbuildinfo coverage",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "peerDependencies": {
    "@nestjs-transactional/core": "workspace:^",
    "@nestjs-transactional/outbox": "workspace:^",
    "@nestjs-transactional/typeorm": "workspace:^",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0",
    "typeorm": "^0.3.25"
  },
  "devDependencies": {
    "@nestjs-transactional/core": "workspace:*",
    "@nestjs-transactional/cqrs": "workspace:*",
    "@nestjs-transactional/outbox": "workspace:*",
    "@nestjs-transactional/typeorm": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@testcontainers/postgresql": "^10.13.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "testcontainers": "^10.13.0",
    "ts-jest": "^29.2.5",
    "typeorm": "^0.3.25",
    "typescript": "^5.5.4"
  }
}
