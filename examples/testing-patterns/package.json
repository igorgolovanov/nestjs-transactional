{
  "name": "@nestjs-transactional-examples/testing-patterns",
  "version": "0.0.0",
  "private": true,
  "description": "Three test tiers for nestjs-transactional code: unit with InMemoryTransactionAdapter, outbox unit with InMemoryEventPublicationRepository + AssertablePublishedEvents, integration with testcontainers Postgres",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js"
  },
  "dependencies": {
    "@nestjs-transactional/core": "workspace:*",
    "@nestjs-transactional/cqrs": "workspace:*",
    "@nestjs-transactional/outbox": "workspace:*",
    "@nestjs-transactional/outbox-typeorm": "workspace:*",
    "@nestjs-transactional/typeorm": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.25"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@testcontainers/postgresql": "^10.13.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "testcontainers": "^10.13.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.5.4"
  }
}
