# Development profile — fast feedback for local iteration.
# Committed example values; no secrets.
NODE_ENV=development

PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=async_config_dev

OUTBOX_POLLING_INTERVAL_MS=100
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_CONCURRENT=10

HTTP_PORT=3000
