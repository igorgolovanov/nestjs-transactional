# Staging profile — closer to production but keeps polling tight
# enough to surface lag in pre-prod observability dashboards.
NODE_ENV=staging

PG_HOST=postgres-staging.internal
PG_PORT=5432
PG_USER=audit_app
PG_PASSWORD=replace-me-via-secret-manager
PG_DATABASE=audit_staging

OUTBOX_POLLING_INTERVAL_MS=500
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_CONCURRENT=20

HTTP_PORT=3000
