# Production profile — slower polling, larger batches, kinder to the
# database under sustained write load. Wire secrets through your
# secret manager (Vault, AWS Secrets Manager, Doppler...) — never
# commit real production values to git.
NODE_ENV=production

PG_HOST=postgres-prod.internal
PG_PORT=5432
PG_USER=audit_app
PG_PASSWORD=replace-me-via-secret-manager
PG_DATABASE=audit_prod

OUTBOX_POLLING_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=500
OUTBOX_MAX_CONCURRENT=50

HTTP_PORT=8080
